# ========================================
# SIRH-SII Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ========================================

# Server
PORT=3000
NODE_ENV=production

# Base de données PostgreSQL (fourni automatiquement par Railway)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Sécurité JWT — Changer absolument en production !
JWT_SECRET="CHANGE_ME_super_secret_jwt_key_production"

# Frontend URL (Vercel) — pour CORS
FRONTEND_URL="https://votre-app.vercel.app"

# Google Gemini AI (Chatbot)
GEMINI_API_KEY=""

# Email SMTP (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SIRH SII"
