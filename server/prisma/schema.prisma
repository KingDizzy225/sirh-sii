generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// 1. EMPLOYEES & CORE SYSTEM
// ----------------------------------------------------

model Employee {
  id              String    @id @default(uuid())
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String    @unique
  role            String    // 'Employee', 'Manager', 'HR', 'Administrator', 'Social Worker'
  department      String
  status          String    // 'ACTIVE', 'ON_LEAVE', 'TERMINATED'
  hireDate        DateTime  @map("hire_date")
  positionTitle   String    @map("position_title")
  managerId       String?   @map("manager_id") // ID du manager direct
  
  // Nouveaux champs RH
  birthDate       DateTime? @map("birth_date")
  gender          String?   @default("Non spécifié")
  phone           String?
  address         String?
  nationality     String?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  annualLeaveBalance Float  @default(30) @map("annual_leave_balance")
  exitDate        DateTime? @map("exit_date")
  offboardingStatus String? @default("N/A") @map("offboarding_status")
  contractType    String?   @default("CDI") @map("contract_type")
  contractEndDate DateTime? @map("contract_end_date")
  trialPeriodEndDate DateTime? @map("trial_period_end_date")

  // Relations
  manager         Employee? @relation("Hierarchy", fields: [managerId], references: [id])
  subordinates    Employee[] @relation("Hierarchy")
  payrolls        Payroll[]
  leaves          Leave[]
  skills          EmployeeSkill[]
  supportTickets  SupportTicket[] @relation("SupportTickets")
  assets          AssetAssignment[]
  participations  TrainingParticipation[]
  performanceGoals PerformanceGoal[] @relation("GoalOwner")
  performanceReviews PerformanceReview[] @relation("ReviewSubject")
  performanceFeedbacks PerformanceFeedback[] @relation("FeedbackSubject")
  documents       EmployeeDocument[] @relation("EmployeeDocs")
  notifications   Notification[] @relation("EmployeeNotifications")
  expenses        Expense[]
  advances        SalaryAdvance[]
  medicalVisits   MedicalVisit[]
  points          EmployeePoints?
  pointEvents     PointEvent[]
  talentProfile   TalentProfile? @relation("EmployeeTalent")
  offboardingTasks OffboardingTask[]
  onboardingTasks  OnboardingTask[]
  shifts          ShiftSchedule[]
  benefits        EmployeeBenefit[]
  timeLogs        TimeLog[]
  absences        Absence[] @relation("EmployeeAbsences")
  careerHistory   CareerHistory[]
  disciplinaryRecords DisciplinaryRecord[]
  kudosSent       Kudo[] @relation("SentKudos")
  kudosReceived   Kudo[] @relation("ReceivedKudos")
  orgNodes        OrgSimulationNode[] @relation("EmployeeOrgNodes")
  successors      Successor[] @relation("EmployeeSuccessors")
  retentionActions RetentionAction[] @relation("EmployeeRetention")
}

// ... (existing code)

// ----------------------------------------------------
// 27. KUDOS (PEER RECOGNITION)
// ----------------------------------------------------

model Kudo {
  id              String   @id @default(uuid())
  senderId        String   @map("sender_id")
  receiverId      String   @map("receiver_id")
  message         String
  category        String   // 'Teamwork', 'Innovation', 'Leadership', 'Efficiency'
  createdAt       DateTime @default(now()) @map("created_at")

  sender          Employee @relation("SentKudos", fields: [senderId], references: [id])
  receiver        Employee @relation("ReceivedKudos", fields: [receiverId], references: [id])
}

// ----------------------------------------------------
// 2. PAIE (PAYROLL)
// ----------------------------------------------------

model Payroll {
  id                      String    @id @default(uuid())
  employeeId              String    @map("employee_id")
  period                  DateTime  // Représente le mois de paie (ex: 2026-01-01)
  baseSalary              Float     @map("base_salary")
  bonus                   Float     @default(0)
  deductions              Float     @default(0)
  overtimeHours           Float     @default(0)   @map("overtime_hours")
  leaveDays               Float     @default(0)   @map("leave_days")
  employerContributions   Float     @default(0)   @map("employer_contributions")
  employeeContributions   Float     @default(0)   @map("employee_contributions")
  netSalary               Float     @default(0)   @map("net_salary")
  pdfPath                 String?   @map("pdf_path")
  status                  String    @default("DRAFT") // 'DRAFT', 'APPROVED', 'PAID'
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt     @map("updated_at")

  employee                Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 3. CONGÉS & ABSENCES (LEAVES)
// ----------------------------------------------------

model Leave {
  id              String    @id @default(uuid())
  employeeId      String    @map("employee_id")
  type            String    // 'Annual', 'Sick', 'Maternity', 'Unpaid'
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  status          String    // 'Pending', 'Approved', 'Rejected'
  durationDays    Float     @map("duration_days")
  reason          String?
  attachmentPath  String?   @map("attachment_path")
  createdAt       DateTime  @default(now()) @map("created_at")

  employee        Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 4. ASSISTANT SOCIAL (SUPPORT TICKETS)
// ----------------------------------------------------

model SupportTicket {
  id              String    @id @default(uuid())
  requesterId     String?   @map("requester_id") // Nullable if anonymous
  category        String    // 'Logement', 'Famille', 'Finances', etc.
  priority        String    // 'Low', 'Medium', 'High', 'Urgent'
  status          String    // 'Ouvert', 'En cours', 'Résolu', 'Fermé'
  isAnonymous     Boolean   @default(false) @map("is_anonymous")
  title           String
  description     String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  requester       Employee? @relation("SupportTickets", fields: [requesterId], references: [id])
  messages        SupportMessage[] @relation("TicketMessages")
}

model SupportMessage {
  id              String   @id @default(uuid())
  ticketId        String   @map("ticket_id")
  sender          String   // 'Employé' ou 'Assistante'
  body            String
  createdAt       DateTime @default(now()) @map("created_at")

  ticket          SupportTicket @relation("TicketMessages", fields: [ticketId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 5. GPEC (COMPÉTENCES)
// ----------------------------------------------------

model EmployeeSkill {
  id                  String    @id @default(uuid())
  employeeId          String    @map("employee_id")
  skillName           String    @map("skill_name")
  proficiencyLevel    String    @map("proficiency_level") // 'Débutant', 'Intermédiaire', 'Avancé', 'Expert'
  interestedInTraining Boolean  @default(false) @map("interested_in_training")
  createdAt           DateTime  @default(now()) @map("created_at")

  employee            Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 6. MATÉRIEL (ASSET MANAGEMENT)
// ----------------------------------------------------

model Asset {
  id              String    @id @default(uuid())
  assetTag        String    @unique @map("asset_tag")
  category        String
  model           String
  status          String    // 'Available', 'Assigned', 'In Repair', 'Retired'
  departmentOwner String    @map("department_owner")
  purchaseDate    DateTime? @map("purchase_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignments     AssetAssignment[]
}

model AssetAssignment {
  id                 String    @id @default(uuid())
  assetId            String    @map("asset_id")
  employeeId         String    @map("employee_id")
  assignedDate       DateTime  @default(now()) @map("assigned_date")
  returnedDate       DateTime? @map("returned_date")
  returnCondition    String?   @map("return_condition")
  
  asset              Asset     @relation(fields: [assetId], references: [id])
  employee           Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 7. COMPLIANCE (AUDIT TRAIL)
// ----------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id") // ID de l'utilisateur qui a fait l'action
  action      String   // PUT, PATCH, DELETE
  tableName   String   @map("table_name")
  recordId    String   @map("record_id")
  oldData     String?  @map("old_data") // JSON en string
  newData     String?  @map("new_data") // JSON en string
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
}

// ----------------------------------------------------
// 8. RECRUTEMENT (JOB OFFERS & APPLICANTS)
// ----------------------------------------------------

model JobOffer {
  id              String    @id @default(uuid())
  title           String
  department      String
  location        String    // ex: 'Abidjan', 'Remote', 'Dakar'
  type            String    // 'CDI', 'CDD', 'Stage', 'Freelance'
  status          String    // 'Active', 'Closed', 'Draft'
  experienceMode  String    @default("Junior") @map("experience_mode")
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  
  applicants      Applicant[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("HR") // ADMIN, HR, MANAGER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Applicant {
  id              String    @id @default(uuid())
  jobOfferId      String    @map("job_offer_id")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String
  phone           String?
  status          String    // 'Applied', 'Screening', 'Interview', 'Offered', 'Hired', 'Rejected'
  matchScore      Int       @default(0) @map("match_score") // Score de correspondance (ex: 85)
  source          String    @default("LinkedIn")
  appliedDate     DateTime  @default(now()) @map("applied_date")
  
  jobOffer        JobOffer  @relation(fields: [jobOfferId], references: [id])
}

// ----------------------------------------------------
// 9. FORMATION (TRAINING MODULES & CAHIER)
// ----------------------------------------------------

model TrainingSession {
  id              String    @id @default(uuid())
  title           String    // Nom du module de formation
  description     String?
  trainerName     String    @map("trainer_name") // Nom du formateur
  date            DateTime  // Date de réalisation
  durationHours   Float     @map("duration_hours") // Durée en heures
  status          String    @default("Completed") // Par défaut les formations ajoutées sont considérées comme effectuées
  createdAt       DateTime  @default(now()) @map("created_at")

  participations  TrainingParticipation[]
  modules         CourseModule[]
}

model TrainingParticipation {
  id                String    @id @default(uuid())
  sessionId         String    @map("session_id")
  employeeId        String    @map("employee_id")
  completionStatus  String    @default("Completed") @map("completion_status")
  createdAt         DateTime  @default(now()) @map("created_at")

  session           TrainingSession @relation(fields: [sessionId], references: [id])
  employee          Employee        @relation(fields: [employeeId], references: [id])

  moduleProgresses  ModuleProgress[]

  @@unique([sessionId, employeeId]) // Un employé ne peut pas participer deux fois à la même session unique
}

model CourseModule {
  id              String   @id @default(uuid())
  sessionId       String   @map("session_id")
  title           String
  content         String?  // Texte riche de la leçon
  mediaUrl        String?  @map("media_url") // Lien externe vers PDF, YouTube, etc.
  orderSequence   Int      @default(0) @map("order_sequence")
  createdAt       DateTime @default(now()) @map("created_at")

  session         TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  progresses      ModuleProgress[]
}

model ModuleProgress {
  id                String   @id @default(uuid())
  participationId   String   @map("participation_id")
  moduleId          String   @map("module_id")
  completedDate     DateTime @default(now()) @map("completed_date")

  participation     TrainingParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  module            CourseModule          @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([participationId, moduleId])
}


// ----------------------------------------------------
// 10. PERFORMANCE & REVIEW
// ----------------------------------------------------

model PerformanceGoal {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  title           String
  category        String   // 'Dév. Professionnel', 'Objectif Commercial', 'Leadership'
  progress        Int      @default(0)
  status          String   @default("En bonne voie") // 'En bonne voie', 'À risque', 'Terminé'
  dueDate         DateTime @map("due_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation("GoalOwner", fields: [employeeId], references: [id], onDelete: Cascade)
}

model PerformanceReview {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  reviewerName    String   @map("reviewer_name")
  cycle           String   // ex: 'Annuel 2026', 'Mi-année 2026'
  rating          String   @default("En attente") // 'Dépasse les attentes', 'Répond aux attentes', etc.
  status          String   @default("Brouillon") // 'Brouillon Soumis', 'Finalisé'
  reviewDate      DateTime @default(now()) @map("review_date")
  achievements    String?
  reflection      String?
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation("ReviewSubject", fields: [employeeId], references: [id], onDelete: Cascade)
}

model PerformanceFeedback {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  provider        String
  relationship    String   @default("Collègue")
  strengths       String?  @default("En attente de retour...")
  areas           String?  @default("En attente de retour...")
  context         String?
  badge           String?  // Pour la gamification 360
  isAnonymous     Boolean  @default(false) @map("is_anonymous")
  peerId          String?  @map("peer_id")
  date            DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation("FeedbackSubject", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 11. GESTION ÉLECTRONIQUE DE DOCUMENTS (GED)
// ----------------------------------------------------

model EmployeeDocument {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  title           String   // Ex: 'Contrat de Travail', 'Fiche de paie Mai'
  type            String   // Ex: 'Paie', 'Contrat', 'Identité', 'Autre'
  filePath        String   @map("file_path") // Le chemin du fichier (ex: /uploads/...)
  fileSize        Int      @default(0) @map("file_size") // en octets
  uploadedBy      String   @map("uploaded_by") // Nom ou ID de la personne ayant uploadé
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation("EmployeeDocs", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 12. NOTIFICATIONS & ALERTES
// ----------------------------------------------------

model Notification {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  message         String
  type            String   @default("Info") // 'Info', 'Alerte', 'Succès'
  isRead          Boolean  @default(false) @map("is_read")
  link            String?  // Lien web de redirection si on clique sur la notif
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation("EmployeeNotifications", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 13. NOTES DE FRAIS (EXPENSES)
// ----------------------------------------------------

model Expense {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  amount          Float
  currency        String   @default("FCFA")
  category        String   // 'Équipement', 'Déplacement', 'Repas', 'Hébergement', 'Autre'
  merchant        String?
  date            DateTime
  status          String   @default("En attente") // 'En attente', 'Approuvé', 'Rejeté'
  rejectionReason String?  @map("rejection_reason")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 14. MUR D'ANNONCES
// ----------------------------------------------------

model Announcement {
  id        String   @id @default(uuid())
  title     String
  body      String
  category  String   @default("Info") // 'Info', 'Urgent', 'Événement', 'Félicitations'
  author    String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

// ----------------------------------------------------
// 15. AVANCES SUR SALAIRE
// ----------------------------------------------------

model SalaryAdvance {
  id                  String    @id @default(uuid())
  employeeId          String    @map("employee_id")
  amount              Float
  reason              String?
  status              String    @default("En attente") // 'En attente', 'Approuvé', 'Rejeté', 'Déduit'
  requestedAt         DateTime  @default(now()) @map("requested_at")
  approvedAt          DateTime? @map("approved_at")
  approvedBy          String?   @map("approved_by")
  deductedOnPayrollId String?   @map("deducted_on_payroll_id")

  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 16. MÉDECINE DU TRAVAIL
// ----------------------------------------------------

model MedicalVisit {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  visitDate    DateTime @map("visit_date")
  expiryDate   DateTime @map("expiry_date") // visitDate + 1 an
  result       String   // 'Apte', 'Apte avec restrictions', 'Inapte temporaire', 'Inapte définitif'
  restrictions String?
  doctor       String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 17. GAMIFICATION & RÉCOMPENSES
// ----------------------------------------------------

model EmployeePoints {
  id         String   @id @default(uuid())
  employeeId String   @unique @map("employee_id")
  total      Int      @default(0)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PointEvent {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  points     Int
  reason     String   // 'Objectif atteint', 'Formation suivie', 'Ancienneté', 'Manuel'
  createdAt  DateTime @default(now()) @map("created_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 18. GPEC++ RÉFÉRENTIEL COMPÉTENCES
// ----------------------------------------------------

model SkillDefinition {
  id          String @id @default(uuid())
  name        String @unique
  category    String // 'Technique', 'Managérial', 'Transversal'
  description String?
  criticality String @default("Normal") // 'Critique', 'Important', 'Normal'
  createdAt   DateTime @default(now()) @map("created_at")
}

// ----------------------------------------------------
// 19. GESTION DES TALENTS (TALENT MANAGEMENT)
// ----------------------------------------------------

model TalentProfile {
  id              String   @id @default(uuid())
  employeeId      String   @unique @map("employee_id")
  potential       String   @default("Medium") // 'Low', 'Medium', 'High'
  performance     String   @default("Medium") // 'Low', 'Medium', 'High'
  flightRisk      String   @default("Low")    // 'Low', 'Medium', 'High'
  readiness       String   @default("1-2 years") // 'Ready now', '1-2 years', '3-5 years'
  lastAssessment  DateTime @default(now()) @map("last_assessment")

  employee        Employee @relation("EmployeeTalent", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 20. ONBOARDING & OFFBOARDING
// ----------------------------------------------------

model OnboardingTask {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  taskName        String   @map("task_name")
  status          String   @default("Pending") // 'Pending', 'In Progress', 'Completed'
  assignedTo      String?  @map("assigned_to")
  dueDate         DateTime? @map("due_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model OffboardingTask {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  taskName        String   @map("task_name")
  status          String   @default("Pending") // 'Pending', 'In Progress', 'Completed'
  assignedTo      String?  @map("assigned_to")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 21. ROSTERING & SHIFT SCHEDULING
// ----------------------------------------------------

model ShiftSchedule {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  date            DateTime
  startTime       String   @map("start_time") // ex: '08:00'
  endTime         String   @map("end_time") // ex: '16:00'
  type            String   @default("Morning") // 'Morning', 'Night', 'Standby'
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 22. BENEFITS & INSURANCE
// ----------------------------------------------------

model EmployeeBenefit {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  type            String   // 'Mutuelle', 'Transport', 'Retraite'
  provider        String   // 'Allianz', 'Navigo'
  planLevel       String   @map("plan_level") // 'Basic', 'Premium', 'Family'
  status          String   @default("Active") // 'Active', 'Pending', 'Cancelled'
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 23. SUBCONTRACTORS & FREELANCE
// ----------------------------------------------------

model Subcontractor {
  id              String   @id @default(uuid())
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  companyName     String   @map("company_name")
  type            String   @default("Freelance") // 'Freelance', 'Interim', 'Consultant'
  startDate       DateTime @map("start_date")
  endDate         DateTime? @map("end_date")
  status          String   @default("Active") // 'Active', 'Terminated'
  rate            Float?   // Taux journalier ou mensuel
  department      String?
  createdAt       DateTime @default(now()) @map("created_at")
}

// ----------------------------------------------------
// 24. WHISTLEBLOWING & ETHICS
// ----------------------------------------------------

model WhistleblowingReport {
  id              String   @id @default(uuid())
  trackingId      String   @unique @map("tracking_id") // ID pour que le lanceur d'alerte puisse suivre
  category        String   // 'Harassment', 'Fraud', 'Safety', 'Discrimination'
  description     String
  status          String   @default("Submitted") // 'Submitted', 'Under Investigation', 'Resolved'
  resolution      String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}




// ----------------------------------------------------
// 21. POINTAGE (TIME & ATTENDANCE)
// ----------------------------------------------------

model TimeLog {
  id          String   @id @default(uuid())
  employeeId  String   @map("employee_id")
  type        String   // 'CLOCK_IN' or 'CLOCK_OUT'
  timestamp   DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 25. ABSENCES & RETARDS
// ----------------------------------------------------

model Absence {
  id               String   @id @default(uuid())
  employeeId       String   @map("employee_id")
  type             String   // 'Retard', 'Absence non justifiée', 'Absence justifiée'
  date             DateTime
  durationMinutes  Int?     @map("duration_minutes")
  justification    String?
  justificatifPath String?  @map("justificatif_path")
  status           String   @default("Non justifié") // 'Non justifié', 'Justifié', 'Contesté'
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  employee         Employee @relation("EmployeeAbsences", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 26. CAREER & DISCIPLINARY
// ----------------------------------------------------

model CareerHistory {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  eventDate       DateTime @map("event_date")
  type            String   // 'PROMOTION', 'DEPARTMENT_CHANGE', 'SALARY_CHANGE', 'HIRE', 'EXIT'
  previousValue   String?  @map("previous_value")
  newValue        String   @map("new_value")
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model DisciplinaryRecord {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  date            DateTime
  type            String   // 'Warning', 'Sanction', 'Blame', 'Suspension'
  reason          String
  sanction        String?
  documentPath    String?  @map("document_path") // PDF de la sanction
  status          String   @default("Active") // 'Active', 'Resolved', 'Contested'
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 29. NOUVELLES FONCTIONNALITES (PHASE 2)
// ----------------------------------------------------

model ComplianceRule {
  id              String   @id @default(uuid())
  title           String
  description     String?
  target          String   // 'ALL', 'DEPARTMENT_X', 'ROLE_Y'
  frequencyMonths Int      // ex: 12 pour 1 an
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}

model WebhookEndpoint {
  id              String   @id @default(uuid())
  name            String
  url             String
  eventType       String   // 'EMPLOYEE_CREATED', 'EMPLOYEE_TERMINATED'
  secret          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
}

// ----------------------------------------------------
// 25. ORG CHART SANDBOX
// ----------------------------------------------------

model OrgSimulation {
  id              String   @id @default(uuid())
  name            String   // Nom du scénario (ex: "Restructuration 2027", "Filiale Dakar")
  description     String?
  createdBy       String   @map("created_by") // L'ID du RH créateur
  status          String   @default("DRAFT") // 'DRAFT', 'APPROVED', 'APPLIED'
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  nodes           OrgSimulationNode[]
}

model OrgSimulationNode {
  id              String   @id @default(uuid())
  simulationId    String   @map("simulation_id")
  
  // Relation Hiérarchique au sein de la simulation
  parentId        String?  @map("parent_id") 
  
  // Option 1 : C'est un employé existant qu'on déplace
  employeeId      String?  @map("employee_id") 
  
  // Option 2 : C'est un nouveau poste vacant ("To Be Hired")
  isVacant        Boolean  @default(false) @map("is_vacant")
  
  // Caractéristiques du nœud dans cette simulation
  title           String   
  department      String   
  monthlySalary   Float    @default(0) @map("monthly_salary") // Permet le calcul d'impact direct
  
  // Relations
  simulation      OrgSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  parent          OrgSimulationNode? @relation("NodeHierarchy", fields: [parentId], references: [id])
  children        OrgSimulationNode[] @relation("NodeHierarchy")
  employee        Employee? @relation("EmployeeOrgNodes", fields: [employeeId], references: [id], onDelete: SetNull)
}

// ----------------------------------------------------
// 26. SUCCESSION PLANNING (MODULE 1)
// ----------------------------------------------------

model SuccessionPlan {
  id              String   @id @default(uuid())
  positionTitle   String   @map("position_title")
  department      String
  criticality     String   @default("Medium") // 'Low', 'Medium', 'High', 'Critical'
  updatedAt       DateTime @updatedAt @map("updated_at")

  successors      Successor[]
}

model Successor {
  id               String   @id @default(uuid())
  planId           String   @map("plan_id")
  employeeId       String   @map("employee_id")
  readiness        String   // 'Ready Now', '1-2 Years', '3+ Years'
  notes            String?  @db.Text

  plan             SuccessionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  employee         Employee       @relation("EmployeeSuccessors", fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 27. JOB DESCRIPTION STUDIO (MODULE 3)
// ----------------------------------------------------

model JobDescription {
  id              String   @id @default(uuid())
  title           String
  department      String
  content         String   @db.Text 
  status          String   @default("DRAFT")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
}

// ----------------------------------------------------
// 28. RETENTION ACTION CENTER (MODULE 5)
// ----------------------------------------------------

model RetentionAction {
  id                String   @id @default(uuid())
  employeeId        String   @map("employee_id")
  riskLevel         String   @map("risk_level") // 'Low', 'Medium', 'High'
  recommendedAction String   @map("recommended_action") @db.Text
  status            String   @default("PENDING") // 'PENDING', 'COMPLETED', 'REJECTED'
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  employee          Employee @relation("EmployeeRetention", fields: [employeeId], references: [id])
}
