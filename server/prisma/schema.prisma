generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// 1. EMPLOYEES & CORE SYSTEM
// ----------------------------------------------------

model Employee {
  id              String    @id @default(uuid())
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String    @unique
  role            String    // 'Employee', 'Manager', 'HR', 'Administrator', 'Social Worker'
  department      String
  status          String    // 'ACTIVE', 'ON_LEAVE', 'TERMINATED'
  hireDate        DateTime  @map("hire_date")
  positionTitle   String    @map("position_title")
  managerId       String?   @map("manager_id") // ID du manager direct
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  manager         Employee? @relation("Hierarchy", fields: [managerId], references: [id])
  subordinates    Employee[] @relation("Hierarchy")
  payrolls        Payroll[]
  leaves          Leave[]
  skills          EmployeeSkill[]
  supportTickets  SupportTicket[] @relation("SupportTickets")
  assets          AssetAssignment[]
  participations  TrainingParticipation[]
  performanceGoals PerformanceGoal[] @relation("GoalOwner")
  performanceReviews PerformanceReview[] @relation("ReviewSubject")
  documents       EmployeeDocument[] @relation("EmployeeDocs")
  notifications   Notification[] @relation("EmployeeNotifications")
}

// ----------------------------------------------------
// 2. PAIE (PAYROLL)
// ----------------------------------------------------

model Payroll {
  id              String    @id @default(uuid())
  employeeId      String    @map("employee_id")
  period          DateTime  // Représente le mois de paie (ex: 2026-01-01)
  baseSalary      Float     @map("base_salary")
  bonus           Float     @default(0)
  deductions      Float     @default(0)
  status          String    // 'Draft', 'Approved', 'Paid'
  createdAt       DateTime  @default(now()) @map("created_at")

  employee        Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 3. CONGÉS & ABSENCES (LEAVES)
// ----------------------------------------------------

model Leave {
  id              String    @id @default(uuid())
  employeeId      String    @map("employee_id")
  type            String    // 'Annual', 'Sick', 'Maternity', 'Unpaid'
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  status          String    // 'Pending', 'Approved', 'Rejected'
  durationDays    Float     @map("duration_days")
  reason          String?
  createdAt       DateTime  @default(now()) @map("created_at")

  employee        Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 4. ASSISTANT SOCIAL (SUPPORT TICKETS)
// ----------------------------------------------------

model SupportTicket {
  id              String    @id @default(uuid())
  requesterId     String?   @map("requester_id") // Nullable if anonymous
  category        String    // 'Logement', 'Famille', 'Finances', etc.
  priority        String    // 'Low', 'Medium', 'High', 'Urgent'
  status          String    // 'Ouvert', 'En cours', 'Résolu', 'Fermé'
  isAnonymous     Boolean   @default(false) @map("is_anonymous")
  title           String
  description     String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  requester       Employee? @relation("SupportTickets", fields: [requesterId], references: [id])
}

// ----------------------------------------------------
// 5. GPEC (COMPÉTENCES)
// ----------------------------------------------------

model EmployeeSkill {
  id                  String    @id @default(uuid())
  employeeId          String    @map("employee_id")
  skillName           String    @map("skill_name")
  proficiencyLevel    String    @map("proficiency_level") // 'Débutant', 'Intermédiaire', 'Avancé', 'Expert'
  interestedInTraining Boolean  @default(false) @map("interested_in_training")
  createdAt           DateTime  @default(now()) @map("created_at")

  employee            Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 6. MATÉRIEL (ASSET MANAGEMENT)
// ----------------------------------------------------

model Asset {
  id              String    @id @default(uuid())
  assetTag        String    @unique @map("asset_tag")
  category        String
  model           String
  status          String    // 'Available', 'Assigned', 'In Repair', 'Retired'
  departmentOwner String    @map("department_owner")
  purchaseDate    DateTime? @map("purchase_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignments     AssetAssignment[]
}

model AssetAssignment {
  id                 String    @id @default(uuid())
  assetId            String    @map("asset_id")
  employeeId         String    @map("employee_id")
  assignedDate       DateTime  @default(now()) @map("assigned_date")
  returnedDate       DateTime? @map("returned_date")
  returnCondition    String?   @map("return_condition")
  
  asset              Asset     @relation(fields: [assetId], references: [id])
  employee           Employee  @relation(fields: [employeeId], references: [id])
}

// ----------------------------------------------------
// 7. COMPLIANCE (AUDIT TRAIL)
// ----------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id") // ID de l'utilisateur qui a fait l'action
  action      String   // PUT, PATCH, DELETE
  tableName   String   @map("table_name")
  recordId    String   @map("record_id")
  oldData     String?  @map("old_data") // JSON en string
  newData     String?  @map("new_data") // JSON en string
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")
}

// ----------------------------------------------------
// 8. RECRUTEMENT (JOB OFFERS & APPLICANTS)
// ----------------------------------------------------

model JobOffer {
  id              String    @id @default(uuid())
  title           String
  department      String
  location        String    // ex: 'Abidjan', 'Remote', 'Dakar'
  type            String    // 'CDI', 'CDD', 'Stage', 'Freelance'
  status          String    // 'Active', 'Closed', 'Draft'
  experienceMode  String    @default("Junior") @map("experience_mode")
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  
  applicants      Applicant[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("HR") // ADMIN, HR, MANAGER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Applicant {
  id              String    @id @default(uuid())
  jobOfferId      String    @map("job_offer_id")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String
  phone           String?
  status          String    // 'Applied', 'Screening', 'Interview', 'Offered', 'Hired', 'Rejected'
  matchScore      Int       @default(0) @map("match_score") // Score de correspondance (ex: 85)
  source          String    @default("LinkedIn")
  appliedDate     DateTime  @default(now()) @map("applied_date")
  
  jobOffer        JobOffer  @relation(fields: [jobOfferId], references: [id])
}

// ----------------------------------------------------
// 9. FORMATION (TRAINING MODULES & CAHIER)
// ----------------------------------------------------

model TrainingSession {
  id              String    @id @default(uuid())
  title           String    // Nom du module de formation
  description     String?
  trainerName     String    @map("trainer_name") // Nom du formateur
  date            DateTime  // Date de réalisation
  durationHours   Float     @map("duration_hours") // Durée en heures
  status          String    @default("Completed") // Par défaut les formations ajoutées sont considérées comme effectuées
  createdAt       DateTime  @default(now()) @map("created_at")

  participations  TrainingParticipation[]
}

model TrainingParticipation {
  id                String    @id @default(uuid())
  sessionId         String    @map("session_id")
  employeeId        String    @map("employee_id")
  completionStatus  String    @default("Completed") @map("completion_status")
  createdAt         DateTime  @default(now()) @map("created_at")

  session           TrainingSession @relation(fields: [sessionId], references: [id])
  employee          Employee        @relation(fields: [employeeId], references: [id])

  @@unique([sessionId, employeeId]) // Un employé ne peut pas participer deux fois à la même session unique
}

// ----------------------------------------------------
// 10. PERFORMANCE & REVIEW
// ----------------------------------------------------

model PerformanceGoal {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  title           String
  category        String   // 'Dév. Professionnel', 'Objectif Commercial', 'Leadership'
  progress        Int      @default(0)
  status          String   @default("En bonne voie") // 'En bonne voie', 'À risque', 'Terminé'
  dueDate         DateTime @map("due_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation("GoalOwner", fields: [employeeId], references: [id], onDelete: Cascade)
}

model PerformanceReview {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  reviewerName    String   @map("reviewer_name")
  cycle           String   // ex: 'Annuel 2026', 'Mi-année 2026'
  rating          String   @default("En attente") // 'Dépasse les attentes', 'Répond aux attentes', etc.
  status          String   @default("Brouillon") // 'Brouillon Soumis', 'Finalisé'
  reviewDate      DateTime @default(now()) @map("review_date")
  achievements    String?
  reflection      String?
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation("ReviewSubject", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 11. GESTION ÉLECTRONIQUE DE DOCUMENTS (GED)
// ----------------------------------------------------

model EmployeeDocument {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  title           String   // Ex: 'Contrat de Travail', 'Fiche de paie Mai'
  type            String   // Ex: 'Paie', 'Contrat', 'Identité', 'Autre'
  filePath        String   @map("file_path") // Le chemin du fichier (ex: /uploads/...)
  fileSize        Int      @default(0) @map("file_size") // en octets
  uploadedBy      String   @map("uploaded_by") // Nom ou ID de la personne ayant uploadé
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employee        Employee @relation("EmployeeDocs", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------
// 12. NOTIFICATIONS & ALERTES
// ----------------------------------------------------

model Notification {
  id              String   @id @default(uuid())
  employeeId      String   @map("employee_id")
  message         String
  type            String   @default("Info") // 'Info', 'Alerte', 'Succès'
  isRead          Boolean  @default(false) @map("is_read")
  link            String?  // Lien web de redirection si on clique sur la notif
  createdAt       DateTime @default(now()) @map("created_at")

  employee        Employee @relation("EmployeeNotifications", fields: [employeeId], references: [id], onDelete: Cascade)
}
